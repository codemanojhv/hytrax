{
  "name": "hytrax",
  "version": "0.1.0-alpha.1",
  "description": "Local, deterministic knowledge layer for AI coding agents. Makes your agent stop repeating mistakes.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "hytrax": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["hytrax", "ai", "coding-agent", "project-knowledge", "harness"],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": { "node": ">=20.0.0" }
}
